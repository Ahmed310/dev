---
import Base from '../layouts/Base.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = [
  {
    id: 'immersed', badge: 'Production', badgeType: 'prod',
    title: 'Immersed',
    card: 'VR metaverse collaboration. I replaced Photon Fusion with my own networking stack (Entangle).',
    preview: { type: 'video', src: '/media/immersed/Immersed_100.mp4' },
    eyebrow: 'immersed · vr metaverse collaboration',
    detailTitle: 'Immersed',
    intro: 'Immersed ran on <strong>Photon Fusion</strong>, which capped scale and drove a steep monthly bill. I replaced it with my own <strong>real-time networking stack</strong> and owned the whole collaboration experience.',
    metrics: [['100+', 'users / room'], ['~65%', 'cloud cost cut']],
    built: [
      'Deployed my own networking framework (<strong>Entangle</strong>) in place of <strong>Photon Fusion</strong>, with area-of-interest and automatic state sync.',
      'Built a cross-platform <strong>VoIP stack</strong> with a C++ core so mobile users could join VR rooms.',
      'Owned the <strong>avatar pipeline</strong> (Genies, Meta, Ready Player Me) and moved room and user state from polling REST to <strong>WebSockets</strong>.',
      'Automated build and deployment on <strong>AWS EC2</strong> (Linux).',
    ],
    videos: [
      { src: '/media/immersed/Immersed_100.mp4', cap: 'Dozens of avatars staying smoothly in sync in one shared room. Entangle scales this to 100+ users.', full: true },
      { src: '/media/immersed/meta_avatar_fullbody_1.mp4', cap: 'Meta full-body avatar networked across peers.' },
      { src: '/media/immersed/meta_avatar_fullbody_2.mp4', cap: 'Full-body avatar tracking, synced in real time.' },
      { src: '/media/immersed/Genies_avatar_1.mp4', cap: 'Genies avatar integration in a shared room.' },
      { src: '/media/immersed/Genies_Avatar_2.mp4', cap: 'Genies avatar networked across users.' },
    ],
    links: [['immersed.com', 'https://immersed.com/']],
  },
  {
    id: 'arthur', badge: 'Production', badgeType: 'prod',
    title: 'Arthur',
    card: 'VR virtual office, scaled to 100+ users on Quest 2 with network LOD and a ground-up WebGL rebuild.',
    preview: { type: 'gif', src: '/media/arthur/NetworkPhysics_Arthur.gif' },
    eyebrow: 'arthur · vr virtual office',
    detailTitle: 'Arthur',
    intro: 'Getting 100+ people into one VR room on a <strong>Quest 2</strong> means fighting two budgets at once: <strong>bandwidth and frame time</strong>. Onboarding also relied on a costly cloud-streaming setup.',
    youtube: 'ONQtTpYkQgE',
    metrics: [['100+', 'users / room'], ['0', 'install friction']],
    built: [
      'Built <strong>network LOD</strong> and networking optimizations to keep bandwidth bounded as the room filled.',
      'Engineered a <strong>Smart Loading System</strong> that hands CPU and GPU budget to what matters (culling IK for out-of-view users, adaptive sharpening).',
      'Led a ground-up <strong>WebGL re-architecture</strong> that replaced costly AWS AppStream streaming, so users could join in a browser with no install.',
      'Designed a <strong>networked physics</strong> system (client-computed, server-distributed) as a microservice.',
    ],
    shots: [
      { src: '/media/arthur/NetworkPhysics_Arthur.gif', cap: 'Networked physics: interactable objects, computed client-side and distributed over the network, stay in sync across the room.' },
      { src: '/media/arthur/NetworkPhysics2_Arthur.gif', cap: 'Consistent physics state across peers, driven by the physics microservice.' },
    ],
    links: [['arthur.digital', 'https://arthur.digital/']],
  },
  {
    id: 'fignet', badge: 'Library', badgeType: 'library',
    title: 'FigNet',
    card: '.NET networking framework with 6,000+ NuGet installs, plus the Entangle room layer and FnVoice engine.',
    preview: { type: 'video', src: '/media/fignet/among_us_mode_300.mp4' },
    eyebrow: 'open source · .net 8 + unity',
    detailTitle: 'FigNet',
    intro: 'My open-source <strong>networking framework</strong> in .NET. On top of it, <strong>Entangle</strong> adds the room and gameplay layer, and <strong>FnVoice</strong> handles real-time voice. Together they cover the parts most teams license.',
    metrics: [['6,000+', 'NuGet downloads'], ['300+', 'players / room']],
    built: [
      '<strong>FigNet</strong>: a transport-agnostic .NET networking framework (ENet, LiteNetLib, WebSocket).',
      '<strong>Entangle</strong>: the room layer, with area-of-interest, subscription and delta replication, three authority models, and self-healing state sync that scales past 300 players.',
      '<strong>FnVoice</strong>: a self-contained voice engine (Opus + native WebRTC DSP) that replaces a commercial dependency, cross-compiled for 7 platforms.',
    ],
    videoCols: 3,
    videos: [
      { src: '/media/fignet/among_us_mode_300.mp4', cap: 'A 100-300 player Among Us-style mode. I built the networking on FigNet.', full: true, link: 'https://www.youtube.com/watch?v=BawdFY6EwVc' },
      { src: '/media/fignet/Immered_100_with_voice.mp4', cap: 'Real-time spatial voice chat in a shared VR room.' },
      { src: '/media/fignet/Immersed_100_with_voice_2.MP4', cap: 'Clear voice across a busy room.' },
      { src: '/media/fignet/Immersed_100_with_voice_3.mp4', cap: 'Low-latency voice at room scale.' },
    ],
    demos: [
      { yt: 'mwcTNEdlgCU', cap: 'Entangle Unity demo: mobile vs PC cross-play, server deployed on AWS.' },
      { src: '/media/games/agar_io_fignet.mp4', cap: 'An Agar.io-style demo built on FigNet.', repo: 'https://github.com/Ahmed310/Agar.FigNet' },
    ],
    links: [
      ['docs', 'https://m-ahmed310.gitbook.io/fignet/'],
      ['nuget', 'https://www.nuget.org/packages/fignet.core.template/'],
      ['among-us demo', 'https://www.youtube.com/watch?v=BawdFY6EwVc'],
      ['asset store', 'https://assetstore.unity.com/packages/tools/network/fignet-207935'],
    ],
  },
];

const games = [
  { id: 'pokervr', name: 'PokerVR', yr: '2018–19', icon: 'PV', youtube: '5L2ZmlkTF1Y',
    desc: 'Social VR poker with a live community, ported to Oculus Quest as a ground-up rebuild and shipped on the store. I owned the systems that let a small team move fast across Rift, Gear/Go and Quest: an automated character pipeline, a draw-call optimization that took the friends UI from roughly 40 draw calls to 1, and a single-codebase build pipeline spanning every platform.',
    body: [
      { h: 'Automated character pipeline', p: 'Adding a new avatar was a manual, hour-long job. I built a Unity editor tool that generates platform-specific prefabs (Rift and Gear/Quest) from an FBX, driven by XML meta data, cutting integration from over an hour to under 5 minutes.',
        yt: 'RtDwnf5qxh4', cap: 'Character creation tool in action.',
        post: ['Read the write-up: character creation', 'https://medium.com/@m.ahmed310.ma/character-creation-in-pokervr-9ebde1ae52eb'] },
      { h: 'Draw-call optimization (~40 to 1)', p: 'Each customized avatar in the friends list cost 3-4 draw calls, up to roughly 40 per page. I pre-rendered every combination into a Texture2DArray and wrote a custom UI shader that billboards each avatar from a single index, collapsing the whole list to one draw call.',
        yt: 'qIODCLX6hKM', cap: 'Automated thumbnail capture from prefabs.',
        post: ['Read the write-up: draw-call optimization', 'https://medium.com/@m.ahmed310.ma/thumbnail-creation-from-prefab-in-unity-pokervr-automated-system-for-draw-call-optimization-2f488d1d7131'] },
      { h: 'Single codebase and build pipeline', p: 'Quest, Rift and Gear/Go started as separate projects. I unified them under one codebase, with code-only scene bases plus per-platform art and editor tools that swap materials, toggle scripting symbols and set build scenes automatically, cutting platform switches from hours to minutes.',
        post: ['Read the write-up: build pipeline and single codebase', 'https://medium.com/@m.ahmed310.ma/build-pipeline-and-single-codebase-management-in-pokervr-9f1547ac5b2d'] },
    ],
    links: [] },
  { id: 'eboh', name: 'Epic Battles of History', yr: '2014–18', video: '/media/games/eboh_game.mp4', desc: 'Historical strategy card game shipped on Steam. As <strong>client-side lead</strong> I set up each of the core game systems, then onboarded junior developers, distributed the work across the team and led it day to day, while still building major features myself. I owned the <strong>editor tooling</strong> and <strong>build automation</strong>, and solved the 2D and 3D art-pipeline integration. I added a <strong>patching system</strong> that shipped only the diff, so players got fast incremental updates instead of full re-downloads. Another major feature was the <strong>replay system</strong>: matches were re-run as a non-interactive <strong>simulation</strong> driven purely by the recorded match history and commands, so any game could be played back exactly as it happened. I also took the title <strong>cross-platform</strong>.', links: [['steam', 'https://store.steampowered.com/app/718750/Epic_Battles_of_History/']] },
  { id: 'coda', name: 'Coda Quest', yr: '2014–18', vimeo: '202066411', icon: 'CQ', desc: 'An online educational RPG that taught kids real skills through play. I worked across the client and server gameplay systems: a <strong>crafting system</strong> for combining materials into new gear, a <strong>player-to-player trading system</strong> with the validation and safeguards an in-game economy needs, and <strong>NPC behavior</strong> that drove quests and world interactions. On the networking side I built the <strong>client/server zone-selection system</strong> that routed players into the correct world zones and kept them synchronized as they moved between areas, so the world stayed populated and responsive.', links: [['watch on vimeo', 'https://vimeo.com/202066411']] },
  { id: 'cthulhu', name: 'Cthulhu Realms', yr: '2014–18', icon: 'CR', youtube: '5GBTm6v-sNQ', desc: 'Digital card game. As a <strong>junior developer</strong> I built the <strong>entire game UI</strong>, back when the new <strong>Unity UI (uGUI)</strong> had only just launched, so a lot of it meant working the system out from first principles.', links: [['play store', 'https://play.google.com/store/apps/details?id=com.whitewizardgames.cthulhurealms']] },
  { id: 'widget', name: 'Widget (UI) Manager', yr: '2016', icon: 'WM', video: '/media/games/widget_manager.mp4', desc: 'Code-free UI animation and management tool, adopted studio-wide and published on the Unity Asset Store.', links: [['asset store', 'https://assetstore.unity.com/packages/tools/gui/widget-ui-manager-57802'], ['video', 'https://www.youtube.com/watch?v=mzMo7oM5Qcw']] },
  { id: 'rgb', name: 'RGB Box Runner', yr: '2015', icon: 'RB', video: '/media/games/rgb_box_runner.mp4', desc: 'A fast-paced endless runner in C#/XNA, built <strong>from scratch</strong> during university summer breaks and featured by Microsoft on the Windows Phone Store in 4 countries. I designed the whole game as <strong>reusable modules</strong>. <strong>Level generation</strong> reads a text file and stitches segments together so the world feels endless, and the same <strong>tile map</strong> both draws the level and drives <strong>collision detection</strong>. UI, buttons and input were built as reusable components, and characters animate through a <strong>sprite-based animation</strong> component. For performance on phones I drew only the <strong>tiles visible on screen</strong>, and each collision check tests the player against just the <strong>9 surrounding tiles</strong> instead of the whole map.', links: [['video', 'https://www.youtube.com/watch?v=dCu4jFfOUMU']] },
  { id: 'brawl', name: 'Brawl Stars Prototype', yr: '2021', icon: 'BS', video: '/media/games/map_editor.mp4', videoCap: 'The custom map editor I built for designing and iterating on arenas.', demo: { yt: '0tlP0HOWCVc', cap: 'Gameplay demo: authoritative server, client-side prediction and lag compensation.' }, desc: 'A hobby prototype recreating Brawl Stars-style top-down multiplayer in Unity. The server is <strong>fully authoritative</strong>, written in C# with <strong>ENet-CSharp</strong> for networking. On top of it I implemented <strong>client-side prediction</strong>, <strong>lag compensation</strong>, and <strong>Network LOD</strong> (each player keeps a proximity list of nearby entities), plus <strong>custom 2D physics</strong> on the server for entity and map collision. I also built a dedicated <strong>map editor</strong> for designing arenas.', links: [['gameplay demo', 'https://www.youtube.com/watch?v=0tlP0HOWCVc']] },
];
---
<Base title="Muhammad Ahmed · game developer & real-time systems" decor="projects">
  <main>
    <div class="wrap">
      <div class="home-intro">
      <p class="eyebrow">// muhammad ahmed</p>
      <h1 class="hero">I build games and the real-time multiplayer<br />systems behind them: the netcode, voice, and infrastructure for shared VR.</h1>

      <div class="prose">
        <p>I'm a game developer with <strong>11+ years</strong> across shipped games and VR productivity apps. Most of that time has gone into one problem wearing different costumes: how do you keep <strong>hundreds of people in sync, in real time</strong>, without the latency or the cloud bill getting out of hand? At <strong>Arthur</strong> I built network LOD and rebuilt the app around WebGL so 100+ people could share a VR room in a browser with no install. At <strong>Immersed</strong> I did the same kind of scaling on my own networking stack instead of a third-party one, which also cut monthly infrastructure cost by around <strong>65%</strong>.</p>

        <p>That stack is open: <strong>FigNet</strong>, a transport-agnostic .NET networking framework; <strong>Entangle</strong>, the room layer that scales a single room past 300 players; and <strong>FnVoice</strong>, a voice engine that replaces a commercial dependency. I trust measurements more than opinions, like working close to the metal (.NET, Unity, a fair amount of C++ interop), and like handing other engineers tools that make the hard thing easy.</p>
      </div>

      <div class="stack">
        <span class="k">stack</span>
        <span class="v"><span>C#</span><span>.NET&nbsp;8</span><span>Unity</span><span>C/C++</span><span>WebGL</span><span>AWS</span><span>real-time&nbsp;netcode</span></span>
      </div>
      </div>

      <h2>featured work</h2>

      <div class="work-grid">
        {projects.map((p) => (
          <button class="pcard" data-modal={p.id} data-track="detail_open" data-track-project={p.id}>
            <div class="pcard-media">
              {p.preview.type === 'video'
                ? <video class="card-video" src={`${b}${p.preview.src}#t=0.1`} muted loop playsinline preload="metadata"></video>
                : <img class="card-img" src={`${b}${p.preview.src}`} alt="" loading="lazy" />}
              <span class={`badge ${p.badgeType}`}>{p.badge}</span>
            </div>
            <div class="pcard-body">
              <h3>{p.title}</h3>
              <p>{p.card}</p>
              <span class="pcta">view case study &rarr;</span>
            </div>
          </button>
        ))}
      </div>

      <h2>games &amp; tools</h2>
      <div class="games-grid">
        {games.map((g) => (
          <button class="gcard" data-modal={g.id} data-track="detail_open" data-track-project={g.id}>
            <div class="gcard-media">
              {g.vimeo
                ? <iframe class="card-video vimeo-bg" src={`https://player.vimeo.com/video/${g.vimeo}?background=1&muted=1&autoplay=1&loop=1&autopause=0`} frameborder="0" allow="autoplay" loading="lazy" tabindex="-1"></iframe>
                : g.youtube
                ? <img class="card-video ytposter" src={`https://i.ytimg.com/vi/${g.youtube}/hqdefault.jpg`} alt="" loading="lazy" />
                : g.video
                ? <video class="card-video" src={`${b}${g.video}#t=0.1`} muted loop playsinline preload="metadata"></video>
                : <span class="gicon">{g.icon}</span>}
            </div>
            <div class="gcard-body"><h4>{g.name}</h4><span class="yr">{g.yr}</span><span class="pcta gcta">view &rarr;</span></div>
          </button>
        ))}
      </div>
    </div>

    {projects.map((p) => (
      <div class="tpl" hidden id={`tpl-${p.id}`}>
        <p class="eyebrow">{p.eyebrow}</p>
        <h3 class="modal-title">{p.detailTitle}</h3>
        <p class="pintro" set:html={p.intro}></p>
        {p.youtube && (<figure class="vid vfull"><div class="vimeo-wrap"><iframe src={`https://www.youtube.com/embed/${p.youtube}?enablejsapi=1`} frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>{p.youtubeCap && (<figcaption>{p.youtubeCap}</figcaption>)}</figure>)}
        <div class="metrics">{p.metrics.map((m) => (<div class="metric"><b>{m[0]}</b><span>{m[1]}</span></div>))}</div>
        <div class="blk"><p class="l">what i built</p><ul>{p.built.map((x) => (<li set:html={x}></li>))}</ul></div>
        {p.videos && (
          <div class="media-stack">
            {p.videos.filter((v) => v.full).map((v) => (
              <figure class="vid vfull">
                <video src={`${b}${v.src}#t=0.1`} controls muted playsinline loop preload="metadata" data-track-project={p.id}></video>
                <figcaption>{v.cap}{v.link && (<span class="cap-link"> &middot; <a href={v.link} data-track="project_link_click" data-track-label="watch_full" data-track-project={p.id}>watch full &rarr;</a></span>)}</figcaption>
              </figure>
            ))}
            {p.videos.some((v) => !v.full) && (
              <div class={p.videoCols === 3 ? 'vids cols3' : 'vids'}>
                {p.videos.filter((v) => !v.full).map((v) => (
                  <figure class="vid"><video src={`${b}${v.src}#t=0.1`} controls muted playsinline loop preload="metadata" data-track-project={p.id}></video><figcaption>{v.cap}</figcaption></figure>
                ))}
              </div>
            )}
          </div>
        )}
        {p.shots && (
          <div class="shots">
            {p.shots.map((s) => (<figure class="shot"><img src={`${b}${s.src}`} alt={s.cap} loading="lazy" /><figcaption>{s.cap}</figcaption></figure>))}
          </div>
        )}
        {p.media && (<div class="proj-media">{p.media}</div>)}
        {p.demos && (<div class="embed-2">{p.demos.map((d) => (<figure class="vid">{d.yt && (<div class="vimeo-wrap"><iframe src={`https://www.youtube.com/embed/${d.yt}?enablejsapi=1`} frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>)}{d.src && (<video src={`${b}${d.src}#t=0.1`} controls muted playsinline loop preload="metadata" data-track-project={p.id}></video>)}<figcaption>{d.cap}{d.repo && (<span class="cap-link"> &middot; <a href={d.repo} data-track="project_link_click" data-track-label="repo" data-track-project={p.id}>repo &rarr;</a></span>)}</figcaption></figure>))}</div>)}
        <div class="links">{p.links.map((l) => (<a href={l[1]} data-track="project_link_click" data-track-label={l[0]} data-track-project={p.id}>{l[0]}</a>))}</div>
      </div>
    ))}
    {games.map((g) => (
      <div class="tpl" hidden id={`tpl-${g.id}`}>
        <p class="eyebrow">games &amp; tools</p>
        <h3 class="modal-title">{g.name} <span class="modal-yr">{g.yr}</span></h3>
        <p class="pintro" set:html={g.desc}></p>
        {g.demo && (<figure class="vid vfull"><div class="vimeo-wrap"><iframe src={`https://www.youtube.com/embed/${g.demo.yt}?enablejsapi=1`} frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div><figcaption>{g.demo.cap}</figcaption></figure>)}
        {g.youtube
          ? (<figure class="vid vfull"><div class="vimeo-wrap"><iframe src={`https://www.youtube.com/embed/${g.youtube}?enablejsapi=1`} frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div></figure>)
          : g.vimeo
          ? (<figure class="vid vfull"><div class="vimeo-wrap"><iframe src={`https://player.vimeo.com/video/${g.vimeo}?title=0&byline=0&portrait=0`} frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe></div></figure>)
          : g.video && (<figure class="vid vfull"><video src={`${b}${g.video}#t=0.1`} controls muted playsinline loop preload="metadata" data-track-project={g.id}></video>{g.videoCap && (<figcaption>{g.videoCap}</figcaption>)}</figure>)}
        {g.body && g.body.map((sec) => (<div class={sec.yt ? "secrow" : "pblock"}><div class="seccol"><h4>{sec.h}</h4><p>{sec.p}</p>{sec.post && (<p class="secmore"><a href={sec.post[1]} data-track="project_link_click" data-track-label="writeup" data-track-project={g.id}>{sec.post[0]} &rarr;</a></p>)}</div>{sec.yt && (<figure class="vid secvid2"><div class="vimeo-wrap"><iframe src={`https://www.youtube.com/embed/${sec.yt}?enablejsapi=1`} frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div><figcaption>{sec.cap}</figcaption></figure>)}</div>))}
        {g.links && g.links.length > 0 && (<div class="links">{g.links.map((l) => (<a href={l[1]} data-track="project_link_click" data-track-label={l[0]} data-track-project={g.id}>{l[0]}</a>))}</div>)}
      </div>
    ))}

    <div id="modal" class="modal" hidden>
      <div class="modal-panel" role="dialog" aria-modal="true">
        <button class="modal-close" aria-label="Close">&#10005;</button>
        <div id="modal-body"></div>
      </div>
    </div>
  </main>
</Base>

<script is:inline>
  const modal = document.getElementById('modal');
  const body = document.getElementById('modal-body');
  const closeBtn = modal.querySelector('.modal-close');

  function openModal(id) {
    const tpl = document.getElementById('tpl-' + id);
    if (!tpl) return;
    body.innerHTML = tpl.innerHTML;
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    const hero = body.querySelector('video');
    if (hero) { hero.muted = true; hero.dataset.autoplayed = '1'; hero.play().catch(() => {}); }
    closeBtn.focus();
  }
  function closeModal() {
    modal.setAttribute('hidden', '');
    body.querySelectorAll('video').forEach((v) => v.pause());
    body.innerHTML = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-modal]').forEach((el) => {
    el.addEventListener('click', () => openModal(el.getAttribute('data-modal')));
  });
  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.hasAttribute('hidden')) closeModal(); });

  const io = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const v = entry.target;
      if (entry.isIntersecting) { v.play().catch(() => {}); }
      else { v.pause(); }
    });
  }, { threshold: 0.35 });
  document.querySelectorAll('.card-video').forEach((v) => io.observe(v));
</script>
