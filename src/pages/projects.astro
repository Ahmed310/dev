---
import Base from '../layouts/Base.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = [
  {
    eyebrow: 'immersed · vr metaverse collaboration',
    title: 'Entangle: my networking stack, in production',
    intro: 'Immersed ran on Photon Fusion, which capped scale and drove a steep monthly bill. I replaced it with my own real-time stack and owned the whole collaboration experience.',
    metrics: [['100+', 'users / room'], ['~65%', 'cloud cost cut']],
    built: [
      'Deployed my own networking framework (Entangle) in place of Photon Fusion, with area-of-interest and automatic state sync.',
      'Built a cross-platform VoIP stack with a C++ core so mobile users could join VR rooms.',
      'Owned the avatar pipeline (Genies, Meta, Ready Player Me) and moved room and user state from polling REST to WebSockets.',
      'Automated build and deployment on AWS EC2 (Linux).',
    ],
    videos: [
      { src: '/media/immersed/Immersed_100.mp4', cap: 'Dozens of avatars staying smoothly in sync in one shared room. Entangle scales this to 100+ users.', full: true },
      { src: '/media/immersed/meta_avatar_fullbody_1.mp4', cap: 'Meta full-body avatar networked across peers.' },
      { src: '/media/immersed/meta_avatar_fullbody_2.mp4', cap: 'Full-body avatar tracking, synced in real time.' },
      { src: '/media/immersed/Genies_avatar_1.mp4', cap: 'Genies avatar integration in a shared room.' },
      { src: '/media/immersed/Genies_Avatar_2.mp4', cap: 'Genies avatar networked across users.' },
    ],
    links: [['immersed.com', 'https://immersed.com/']],
  },
  {
    eyebrow: 'arthur · vr virtual office',
    title: 'Scaling VR meetings to 100+ on a Quest 2',
    intro: 'Getting 100+ people into one VR room on a Quest 2 means fighting two budgets at once: bandwidth and frame time. Onboarding also relied on a costly cloud-streaming setup.',
    metrics: [['100+', 'users / room'], ['0', 'install friction']],
    built: [
      'Built network LOD and networking optimizations to keep bandwidth bounded as the room filled.',
      'Engineered a Smart Loading System that hands CPU and GPU budget to what matters (culling IK for out-of-view users, adaptive sharpening).',
      'Led a ground-up WebGL re-architecture that replaced costly AWS AppStream streaming, so users could join in a browser with no install.',
      'Designed a networked physics system (client-computed, server-distributed) as a microservice.',
    ],
    shots: [
      { src: '/media/arthur/NetworkPhysics_Arthur.gif', cap: 'Networked physics: interactable objects, computed client-side and distributed over the network, stay in sync across the room.' },
      { src: '/media/arthur/NetworkPhysics2_Arthur.gif', cap: 'Consistent physics state across peers, driven by the physics microservice.' },
    ],
    links: [['arthur.digital', 'https://arthur.digital/']],
  },
  {
    eyebrow: 'open source · .net 8 + unity',
    title: 'FigNet',
    intro: 'My open-source networking framework in .NET. On top of it, Entangle adds the room and gameplay layer, and FnVoice handles real-time voice. Together they cover the parts most teams license.',
    metrics: [['6,000+', 'NuGet downloads'], ['300+', 'players / room'], ['7', 'voice platforms']],
    built: [
      'FigNet: a transport-agnostic .NET networking framework (ENet, LiteNetLib, WebSocket).',
      'Entangle: the room layer, with area-of-interest, subscription and delta replication, three authority models, and self-healing state sync that scales past 300 players.',
      'FnVoice: a self-contained voice engine (Opus + native WebRTC DSP) that replaces a commercial dependency, cross-compiled for 7 platforms.',
    ],
    videoCols: 3,
    videos: [
      { src: '/media/fignet/among_us_mode_300.mp4', cap: 'A 100-300 player Among Us-style mode, powered by FigNet.', full: true, link: 'https://www.youtube.com/watch?v=BawdFY6EwVc' },
      { src: '/media/fignet/Immered_100_with_voice.mp4', cap: 'Real-time spatial voice chat in a shared VR room.' },
      { src: '/media/fignet/Immersed_100_with_voice_2.MP4', cap: 'Clear voice across a busy room.' },
      { src: '/media/fignet/Immersed_100_with_voice_3.mp4', cap: 'Low-latency voice at room scale.' },
    ],
    media: 'diagram: Entangle architecture + AOI spatial grid (coming soon)',
    links: [
      ['docs', 'https://m-ahmed310.gitbook.io/fignet/'],
      ['nuget', 'https://www.nuget.org/packages/fignet.core.template/'],
      ['among-us demo', 'https://www.youtube.com/watch?v=BawdFY6EwVc'],
      ['asset store', 'https://assetstore.unity.com/packages/tools/network/fignet-207935'],
    ],
  },
];

const games = [
  { name: 'PokerVR', yr: '2018–19', desc: 'Social VR poker, ported to Oculus Quest as a ground-up rebuild and shipped on the store. I built the avatar-UI draw-call optimization (~40 to 1), automated the character pipeline, and set up studio-wide builds.', links: [['quest', 'https://www.oculus.com/experiences/quest/2257223740990488/'], ['gameplay', 'https://www.youtube.com/watch?v=tQGCVHw2rTk'], ['engineering notes', 'https://medium.com/@m.ahmed310.ma/thumbnail-creation-from-prefab-in-unity-pokervr-automated-system-for-draw-call-optimization-2f488d1d7131']] },
  { name: 'Epic Battles of History', yr: '2014–18', desc: 'Historical strategy title. Led client-side architecture and core gameplay, built editor tooling, and mentored client engineers.', video: '/media/games/eboh_game.mp4', links: [['steam', 'https://store.steampowered.com/app/718750/Epic_Battles_of_History/']] },
  { name: 'Coda Quest', yr: '2014–18', desc: 'Online educational RPG. Built crafting, in-game trading, NPC behavior, and client/server zone selection.', links: [['video', 'https://vimeo.com/202066411']] },
  { name: 'Cthulhu Realms', yr: '2014–18', desc: 'Digital card game. Built the game UI in Unity UGUI.', links: [['play store', 'https://play.google.com/store/apps/details?id=com.whitewizardgames.cthulhurealms'], ['video', 'https://www.youtube.com/watch?v=5GBTm6v-sNQ']] },
  { name: 'Widget (UI) Manager', yr: '2016', desc: 'Code-free UI animation and management tool, adopted studio-wide and published on the Unity Asset Store.', links: [['asset store', 'https://assetstore.unity.com/packages/tools/gui/widget-ui-manager-57802'], ['video', 'https://www.youtube.com/watch?v=mzMo7oM5Qcw']] },
  { name: 'RGB Box Runner', yr: '2015', desc: 'Fast-paced endless runner in C#/XNA, featured by Microsoft on the Windows Phone Store in 4 countries.', links: [['video', 'https://www.youtube.com/watch?v=dCu4jFfOUMU']] },
];
---
<Base title="Projects · Muhammad Ahmed">
  <main>
    <div class="wrap">
      <p class="eyebrow">// projects</p>
      <h1 class="hero">Selected work.</h1>

      <div class="cards">
        {projects.map((p) => (
          <div class="card">
            <p class="role">{p.eyebrow}</p>
            <h3>{p.title}</h3>
            <p class="pintro">{p.intro}</p>
            <div class="metrics">
              {p.metrics.map((m) => (<div class="metric"><b>{m[0]}</b><span>{m[1]}</span></div>))}
            </div>
            <div class="blk">
              <p class="l">what i built</p>
              <ul>{p.built.map((x) => (<li>{x}</li>))}</ul>
            </div>
            {p.videos && (
              <div class="media-stack">
                {p.videos.filter((v) => v.full).map((v) => (
                  <figure class="vid vfull">
                    <video src={`${b}${v.src}#t=0.1`} controls muted playsinline loop preload="metadata"></video>
                    <figcaption>{v.cap}{v.link && (<span class="cap-link"> &middot; <a href={v.link}>watch full &rarr;</a></span>)}</figcaption>
                  </figure>
                ))}
                {p.videos.some((v) => !v.full) && (
                  <div class={p.videoCols === 3 ? "vids cols3" : "vids"}>
                    {p.videos.filter((v) => !v.full).map((v) => (
                      <figure class="vid">
                        <video src={`${b}${v.src}#t=0.1`} controls muted playsinline loop preload="metadata"></video>
                        <figcaption>{v.cap}{v.link && (<span class="cap-link"> &middot; <a href={v.link}>watch full &rarr;</a></span>)}</figcaption>
                      </figure>
                    ))}
                  </div>
                )}
              </div>
            )}
            {p.shots && (
              <div class="shots">
                {p.shots.map((s) => (
                  <figure class="shot">
                    <img src={`${b}${s.src}`} alt={s.cap} loading="lazy" />
                    <figcaption>{s.cap}</figcaption>
                  </figure>
                ))}
              </div>
            )}
            {p.media && (<div class="proj-media">{p.media}</div>)}
            <div class="links">{p.links.map((l) => (<a href={l[1]}>{l[0]}</a>))}</div>
          </div>
        ))}
      </div>

      <h2>games &amp; tools</h2>
      <div class="games">
        {games.map((g) => (
          <div class="game">
            <div class="game-head"><a href={g.links[0][1]}>{g.name}</a><span class="yr">{g.yr}</span></div>
            <p class="game-desc">{g.desc}</p>
            {g.video && (
              <figure class="vid gvid">
                <video src={`${b}${g.video}#t=0.1`} controls muted playsinline loop preload="metadata"></video>
              </figure>
            )}
            <div class="glinks">{g.links.map((l) => (<a href={l[1]}>{l[0]}</a>))}</div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Base>
