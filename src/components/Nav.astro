---
const base = import.meta.env.BASE_URL;
const b = base.replace(/\/$/, '');
const to = (seg: string) => (seg === '' ? base : `${b}/${seg}`);
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (seg: string) => path === (seg === '' ? (b || '/') : `${b}/${seg}`);
---
<nav>
  <div class="wrap">
    <a class="brand" href={to('')}>Ahmed<span class="dot">.</span></a>
    <div class="navlinks">
      <a href={to('')} class={isActive('') ? 'active' : ''}>home</a>
      <a href={to('about')} class={isActive('about') ? 'active' : ''}>about</a>
      <a href={to('projects')} class={isActive('projects') ? 'active' : ''}>projects</a>
      <a href={to('blog')} class={isActive('blog') ? 'active' : ''}>blog</a>
    </div>
  </div>
</nav>
