---
interface Props { page?: string; }
const { page = 'home' } = Astro.props;

const motifs: Record<string, string> = {
  network: `<svg width="150" height="210" viewBox="0 0 150 210" fill="none"><g stroke="rgba(150,160,175,.6)" stroke-width="1"><line x1="30" y1="30" x2="92" y2="62"/><line x1="92" y1="62" x2="40" y2="112"/><line x1="92" y1="62" x2="122" y2="122"/><line x1="40" y1="112" x2="122" y2="122"/><line x1="40" y1="112" x2="72" y2="180"/><line x1="122" y1="122" x2="72" y2="180"/></g><circle class="nd" cx="30" cy="30" r="4"/><circle class="nd" cx="92" cy="62" r="5.5"/><circle class="nd" cx="40" cy="112" r="4"/><circle class="nd" cx="122" cy="122" r="4"/><circle class="nd" cx="72" cy="180" r="4.5"/></svg>`,
  spatial: `<svg width="180" height="180" viewBox="0 0 180 180" fill="none"><g stroke="rgba(150,160,175,.55)"><circle cx="90" cy="90" r="30"/><circle cx="90" cy="90" r="56"/><circle cx="90" cy="90" r="82"/></g><circle cx="90" cy="90" r="3.5" fill="rgba(126,225,196,.7)"/><g class="orbit"><circle cx="90" cy="34" r="4.5" fill="rgba(126,225,196,.75)"/></g></svg>`,
  cube: `<svg class="floaty" width="150" height="170" viewBox="0 0 150 170" fill="none"><g stroke="rgba(150,160,175,.62)" stroke-width="1.2"><path d="M75 18 L130 50 L130 114 L75 146 L20 114 L20 50 Z"/><path d="M75 18 L75 82 M75 82 L130 50 M75 82 L20 50 M75 82 L75 146"/></g><circle cx="75" cy="82" r="3" fill="rgba(126,225,196,.75)"/></svg>`,
  voice: `<svg width="126" height="110" viewBox="0 0 126 110" fill="rgba(126,225,196,.7)"><rect class="bar" x="10" y="30" width="8" height="60" rx="3"/><rect class="bar" x="27" y="30" width="8" height="60" rx="3"/><rect class="bar" x="44" y="30" width="8" height="60" rx="3"/><rect class="bar" x="61" y="30" width="8" height="60" rx="3"/><rect class="bar" x="78" y="30" width="8" height="60" rx="3"/><rect class="bar" x="95" y="30" width="8" height="60" rx="3"/></svg>`,
  game: `<svg class="bobby" width="150" height="92" viewBox="0 0 150 92" fill="none"><rect x="22" y="26" width="106" height="42" rx="21" stroke="rgba(150,160,175,.62)" stroke-width="1.4"/><g stroke="rgba(150,160,175,.62)" stroke-width="2" stroke-linecap="round"><line x1="44" y1="47" x2="60" y2="47"/><line x1="52" y1="39" x2="52" y2="55"/></g><circle cx="99" cy="40" r="4" fill="rgba(126,225,196,.75)"/><circle cx="111" cy="52" r="4" fill="rgba(126,225,196,.75)"/></svg>`,
  code: `<svg class="glow" width="132" height="84" viewBox="0 0 132 84" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M42 22 L20 42 L42 62" stroke="rgba(150,160,175,.64)" stroke-width="2.2"/><path d="M90 22 L112 42 L90 62" stroke="rgba(150,160,175,.64)" stroke-width="2.2"/><path d="M76 16 L56 68" stroke="rgba(126,225,196,.7)" stroke-width="2.2"/></svg>`,
  globe: `<svg class="globe" viewBox="0 0 140 140" fill="none" stroke="rgba(150,160,175,.55)" stroke-width="1"><circle cx="70" cy="70" r="60"/><ellipse cx="70" cy="70" rx="60" ry="22"/><ellipse cx="70" cy="70" rx="60" ry="44"/><g class="meridians"><ellipse cx="70" cy="70" rx="22" ry="60"/><ellipse cx="70" cy="70" rx="44" ry="60"/></g><circle cx="70" cy="70" r="3" fill="rgba(126,225,196,.75)" stroke="none"/></svg>`,
  atom: `<svg class="atom" viewBox="0 0 140 140" fill="none"><g stroke="rgba(150,160,175,.5)" stroke-width="1"><ellipse cx="70" cy="70" rx="60" ry="24"/><ellipse cx="70" cy="70" rx="60" ry="24" transform="rotate(60 70 70)"/><ellipse cx="70" cy="70" rx="60" ry="24" transform="rotate(120 70 70)"/></g><circle cx="70" cy="70" r="3.5" fill="rgba(126,225,196,.75)"/><g class="e1"><circle cx="130" cy="70" r="3.5" fill="rgba(126,225,196,.85)"/></g><g class="e2"><circle cx="130" cy="70" r="3.5" fill="rgba(126,225,196,.85)"/></g></svg>`,
  isostack: `<svg class="floaty" viewBox="0 0 100 100" fill="none" stroke="rgba(150,160,175,.6)" stroke-width="1.2"><path d="M50 18 L82 34 L50 50 L18 34 Z"/><path d="M50 40 L82 56 L50 72 L18 56 Z"/><path d="M50 62 L82 78 L50 94 L18 78 Z"/><circle cx="50" cy="34" r="2.5" fill="rgba(126,225,196,.7)" stroke="none"/></svg>`,
  pyramid: `<svg viewBox="0 0 100 100" fill="none" stroke="rgba(150,160,175,.6)" stroke-width="1.2"><g class="floaty" style="animation-delay:-2.5s"><path d="M50 15 L85 70 L15 70 Z"/><path d="M50 15 L50 82 L85 70 M50 82 L15 70"/><circle cx="50" cy="82" r="3" fill="rgba(126,225,196,.7)" stroke="none"/></g></svg>`,
  packet: `<svg viewBox="0 0 110 100" fill="none"><path d="M15 78 L42 40 L72 60 L95 22" stroke="rgba(150,160,175,.55)" stroke-width="1.5"/><circle cx="15" cy="78" r="4" fill="rgba(150,160,175,.75)"/><circle cx="42" cy="40" r="4" fill="rgba(150,160,175,.75)"/><circle cx="72" cy="60" r="4" fill="rgba(150,160,175,.75)"/><circle cx="95" cy="22" r="4" fill="rgba(150,160,175,.75)"/><circle r="3.5" fill="rgba(126,225,196,.95)"><animateMotion dur="3s" repeatCount="indefinite" path="M15 78 L42 40 L72 60 L95 22"/></circle></svg>`,
  reticle: `<svg viewBox="0 0 100 100" fill="none" stroke="rgba(126,225,196,.6)"><circle class="reticle-ring" cx="50" cy="50" r="30" stroke-width="1.5" stroke-dasharray="6 11"/><path d="M50 10 v10 M50 80 v10 M10 50 h10 M80 50 h10" stroke="rgba(150,160,175,.7)" stroke-width="1.5"/><circle cx="50" cy="50" r="4" fill="rgba(126,225,196,.75)" stroke="none"/></svg>`,
};

const patterns: Record<string, string> = {
  rings: `<svg class="pat" viewBox="0 0 1440 640" preserveAspectRatio="xMidYMin slice" fill="none"><g stroke="rgba(126,225,196,.12)"><circle cx="720" cy="30" r="120"/><circle cx="720" cy="30" r="230"/><circle cx="720" cy="30" r="350"/><circle cx="720" cy="30" r="480"/><circle cx="720" cy="30" r="620"/></g><circle class="radar" cx="720" cy="30" r="150" fill="none" stroke="rgba(126,225,196,.55)" stroke-width="1.5"/><g class="sweep"><line x1="720" y1="30" x2="720" y2="640" stroke="rgba(126,225,196,.22)" stroke-width="2"/></g></svg>`,
  constellation: `<svg class="pat" viewBox="0 0 1440 640" preserveAspectRatio="xMidYMid slice" fill="none"><g stroke="rgba(150,160,175,.13)"><line x1="120" y1="140" x2="320" y2="240"/><line x1="320" y1="240" x2="200" y2="400"/><line x1="320" y1="240" x2="560" y2="180"/><line x1="1120" y1="110" x2="1280" y2="250"/><line x1="1280" y1="250" x2="1100" y2="400"/><line x1="900" y1="320" x2="1100" y2="400"/></g><g fill="rgba(126,225,196,.42)"><circle class="nd" cx="120" cy="140" r="3.5"/><circle class="nd" cx="320" cy="240" r="4.5"/><circle cx="200" cy="400" r="3.5"/><circle cx="560" cy="180" r="3"/><circle class="nd" cx="1120" cy="110" r="3.5"/><circle class="nd" cx="1280" cy="250" r="4.5"/><circle cx="1100" cy="400" r="3.5"/><circle cx="900" cy="320" r="3"/></g></svg>`,
  waves: `<svg class="pat" viewBox="0 0 1440 260" preserveAspectRatio="none" fill="none"><path d="M0 90 C 240 30 480 150 720 90 S 1200 30 1440 90" stroke="rgba(150,160,175,.1)" stroke-width="1.5"/><path d="M0 130 C 240 70 480 190 720 130 S 1200 70 1440 130" stroke="rgba(126,225,196,.17)" stroke-width="1.5"/><path d="M0 170 C 240 110 480 230 720 170 S 1200 110 1440 170" stroke="rgba(126,225,196,.1)" stroke-width="1.5"/></svg>`,
  plus: `<svg class="pat" viewBox="0 0 1440 640" preserveAspectRatio="xMidYMid slice"><defs><pattern id="plusgrid" width="46" height="46" patternUnits="userSpaceOnUse"><path d="M23 15 v16 M15 23 h16" stroke="rgba(96,150,235,.2)" stroke-width="1.2" stroke-linecap="round"/></pattern></defs><rect width="1440" height="640" fill="url(#plusgrid)"/></svg>`,
  radar: `<svg class="pat" viewBox="0 0 1440 640" preserveAspectRatio="xMidYMin slice" fill="none"><g stroke="rgba(126,225,196,.08)"><circle cx="720" cy="18" r="150"/><circle cx="720" cy="18" r="310"/><circle cx="720" cy="18" r="470"/><circle cx="720" cy="18" r="630"/></g><g class="hsweep"><line x1="720" y1="18" x2="720" y2="660" stroke="rgba(126,225,196,.26)" stroke-width="1.5"/><line x1="720" y1="18" x2="686" y2="660" stroke="rgba(126,225,196,.12)" stroke-width="1"/><line x1="720" y1="18" x2="654" y2="654" stroke="rgba(126,225,196,.06)" stroke-width="1"/></g></svg>`,
  honeycomb: `<svg class="pat" viewBox="0 0 1440 640" preserveAspectRatio="xMidYMid slice" fill="none" stroke="rgba(150,120,240,.2)"><defs><pattern id="hxg" width="36" height="62" patternUnits="userSpaceOnUse" patternTransform="scale(1.5)"><path d="M18 0 L36 10.4 L36 31.2 L18 41.6 L0 31.2 L0 10.4 Z" fill="none" stroke-width="1"/><path d="M18 41.6 L18 62 M36 31.2 L54 41.6 M0 31.2 L-18 41.6" stroke-width="1"/></pattern></defs><rect width="1440" height="640" fill="url(#hxg)"/></svg>`,
};

const cfg: Record<string, { glow: string; pattern: string; top: string; bottom: string }> = {
  home: { glow: 'teal', pattern: 'grid', top: 'atom', bottom: 'cube' },
  about: { glow: 'teal', pattern: 'radar', top: 'isostack', bottom: 'pyramid' },
  projects: { glow: 'violet', pattern: 'honeycomb', top: 'reticle', bottom: 'game' },
  blog: { glow: 'teal', pattern: 'matrix', top: 'code', bottom: 'packet' },
};
const c = cfg[page] || cfg.home;
---
<div class={`hero-bg glow-${c.glow}`} aria-hidden="true">
  {c.pattern === 'matrix' ? <canvas class="hero-matrix"></canvas> : c.pattern === 'grid' ? <div class="hero-grid"><div class="grid-half grid-top"><div class="hero-grid-floor"></div></div><div class="grid-half grid-bot"><div class="hero-grid-floor"></div></div></div> : c.pattern === 'dots' ? <div class="hero-dots"></div> : c.pattern === 'iso' ? <div class="hero-iso"></div> : c.pattern === 'radar' ? (<div class="hero-radar"><svg class="radar-rings" viewBox="0 0 1440 640" preserveAspectRatio="xMidYMin slice" fill="none"><g stroke="rgba(126,225,196,.08)"><circle cx="720" cy="18" r="150"/><circle cx="720" cy="18" r="310"/><circle cx="720" cy="18" r="470"/><circle cx="720" cy="18" r="630"/></g><circle cx="720" cy="18" r="3" fill="rgba(126,225,196,.5)"/></svg><div class="radar-sweep"></div></div>) : <div class="hero-pattern" set:html={patterns[c.pattern]}></div>}
</div>
<div class="col-deco" aria-hidden="true">
  <div class={`deco deco-top${c.top === 'reticle' ? ' wander' : ''}`} set:html={motifs[c.top]}></div>
  <div class="deco deco-bottom" set:html={motifs[c.bottom]}></div>
</div>

<script is:inline>
(function(){
  var cv=document.querySelector('canvas.hero-matrix'); if(!cv) return;
  var ctx=cv.getContext('2d');
  var fs=14, chars='アカサタナﾊﾋﾌﾔﾗ0123456789<>{}[]=+*ABCDEF'.split(''), drops=[], cols=0, dpr=Math.min(window.devicePixelRatio||1,2);
  function resize(){ var w=cv.clientWidth,h=cv.clientHeight; cv.width=w*dpr; cv.height=h*dpr; ctx.setTransform(dpr,0,0,dpr,0,0); cols=Math.floor(w/fs); drops=Array(cols).fill(0).map(function(){return Math.random()*-30;}); ctx.clearRect(0,0,w,h); }
  resize(); window.addEventListener('resize',resize);
  setInterval(function(){
    var w=cv.clientWidth,h=cv.clientHeight;
    ctx.fillStyle='rgba(11,13,17,0.16)'; ctx.fillRect(0,0,w,h);
    ctx.font=fs+'px "JetBrains Mono", monospace';
    for(var i=0;i<cols;i++){
      var t=chars[Math.floor(Math.random()*chars.length)], y=drops[i]*fs;
      ctx.fillStyle='rgba(230,255,245,0.85)'; ctx.fillText(t,i*fs,y);
      ctx.fillStyle='rgba(126,225,196,0.5)'; ctx.fillText(t,i*fs,y-fs);
      if(y>h && Math.random()>0.977) drops[i]=0;
      drops[i]++;
    }
  },80);
})();
</script>