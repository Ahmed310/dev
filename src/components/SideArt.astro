---
interface Props { page?: string; }
const { page = 'home' } = Astro.props;

const motifs: Record<string, string> = {
  network: `<svg width="150" height="210" viewBox="0 0 150 210" fill="none"><g stroke="rgba(139,147,161,.32)" stroke-width="1"><line x1="30" y1="30" x2="92" y2="62"/><line x1="92" y1="62" x2="40" y2="112"/><line x1="92" y1="62" x2="122" y2="122"/><line x1="40" y1="112" x2="122" y2="122"/><line x1="40" y1="112" x2="72" y2="180"/><line x1="122" y1="122" x2="72" y2="180"/></g><circle class="nd" cx="30" cy="30" r="4"/><circle class="nd" cx="92" cy="62" r="5.5"/><circle class="nd" cx="40" cy="112" r="4"/><circle class="nd" cx="122" cy="122" r="4"/><circle class="nd" cx="72" cy="180" r="4.5"/></svg>`,
  spatial: `<svg width="180" height="180" viewBox="0 0 180 180" fill="none"><g stroke="rgba(139,147,161,.28)"><circle cx="90" cy="90" r="30"/><circle cx="90" cy="90" r="56"/><circle cx="90" cy="90" r="82"/></g><circle cx="90" cy="90" r="3.5" fill="rgba(126,225,196,.7)"/><g class="orbit"><circle cx="90" cy="34" r="4.5" fill="rgba(126,225,196,.75)"/></g></svg>`,
  cube: `<svg class="floaty" width="150" height="170" viewBox="0 0 150 170" fill="none"><g stroke="rgba(139,147,161,.38)" stroke-width="1.2"><path d="M75 18 L130 50 L130 114 L75 146 L20 114 L20 50 Z"/><path d="M75 18 L75 82 M75 82 L130 50 M75 82 L20 50 M75 82 L75 146"/></g><circle cx="75" cy="82" r="3" fill="rgba(126,225,196,.6)"/></svg>`,
  voice: `<svg width="126" height="110" viewBox="0 0 126 110" fill="rgba(126,225,196,.5)"><rect class="bar" x="10" y="30" width="8" height="60" rx="3"/><rect class="bar" x="27" y="30" width="8" height="60" rx="3"/><rect class="bar" x="44" y="30" width="8" height="60" rx="3"/><rect class="bar" x="61" y="30" width="8" height="60" rx="3"/><rect class="bar" x="78" y="30" width="8" height="60" rx="3"/><rect class="bar" x="95" y="30" width="8" height="60" rx="3"/></svg>`,
  game: `<svg class="bobby" width="150" height="92" viewBox="0 0 150 92" fill="none"><rect x="22" y="26" width="106" height="42" rx="21" stroke="rgba(139,147,161,.4)" stroke-width="1.4"/><g stroke="rgba(139,147,161,.4)" stroke-width="2" stroke-linecap="round"><line x1="44" y1="47" x2="60" y2="47"/><line x1="52" y1="39" x2="52" y2="55"/></g><circle cx="99" cy="40" r="4" fill="rgba(126,225,196,.6)"/><circle cx="111" cy="52" r="4" fill="rgba(126,225,196,.6)"/></svg>`,
  code: `<svg class="glow" width="132" height="84" viewBox="0 0 132 84" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M42 22 L20 42 L42 62" stroke="rgba(139,147,161,.45)" stroke-width="2.2"/><path d="M90 22 L112 42 L90 62" stroke="rgba(139,147,161,.45)" stroke-width="2.2"/><path d="M76 16 L56 68" stroke="rgba(126,225,196,.5)" stroke-width="2.2"/></svg>`,
};

const map: Record<string, [string, string]> = {
  home: ['network', 'cube'],
  about: ['spatial', 'voice'],
  projects: ['cube', 'game'],
  blog: ['code', 'network'],
};
const [left, right] = map[page] || map.home;
---
<div class="side-art left" aria-hidden="true" set:html={motifs[left]}></div>
<div class="side-art right" aria-hidden="true" set:html={motifs[right]}></div>
